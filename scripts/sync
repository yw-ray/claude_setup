#!/usr/bin/env bash
# sync - Rebase current branch onto a target (upstream/main, branch name, or PR branch)
# Usage: sync [branch_name|PR_number]
# Uses: git rebase --onto only (never plain git rebase <target>)
# See: ~/.claude/commands/sync.md

set -e

CACHE_DIR=".cache"
PR_CACHE_FILE="${CACHE_DIR}/pr_cache.json"
GH_HOST="github.mangoboost.io"

# --- Resolve owner/repo for gh api (e.g. MangoBoost/mats-monorepo) ---
get_repo_slug() {
  local slug=""
  if command -v gh &>/dev/null; then
    slug=$(gh repo view --json nameWithOwner -q .nameWithOwner 2>/dev/null) || true
  fi
  if [[ -z "$slug" ]]; then
    local url
    url=$(git config --get remote.upstream.url 2>/dev/null) || url=$(git config --get remote.origin.url 2>/dev/null)
    if [[ "$url" =~ (github\.com|github\.mangoboost\.io)[:/]([^/]+/[^/.]+) ]]; then
      slug="${BASH_REMATCH[2]}"
    fi
  fi
  echo "$slug"
}

# --- Ensure pr cache dir exists ---
ensure_pr_cache() {
  mkdir -p "$CACHE_DIR"
  if [[ ! -f "$PR_CACHE_FILE" ]]; then
    echo '{}' > "$PR_CACHE_FILE"
  fi
}

# --- Get PR branch info from cache or gh api ---
# Returns JSON: {"head":"<ref>","headRepo":"<full_name>"}
get_pr_branch_info() {
  local pr_number="$1"
  local slug="$2"
  ensure_pr_cache
  local cached
  cached=$(jq -r --arg pr "$pr_number" '.[$pr] // empty' "$PR_CACHE_FILE" 2>/dev/null)
  if [[ -n "$cached" ]]; then
    echo "$cached"
    return
  fi
  local jq_query='{head: .head.ref, headRepo: .head.repo.full_name}'
  local out
  out=$(gh api "repos/${slug}/pulls/${pr_number}" --hostname "$GH_HOST" --jq "$jq_query" 2>/dev/null) || true
  if [[ -z "$out" ]]; then
    echo "sync: failed to get PR #${pr_number} (gh auth or network?)." >&2
    exit 1
  fi
  local head headRepo
  head=$(echo "$out" | jq -r '.head')
  headRepo=$(echo "$out" | jq -r '.headRepo')
  jq --arg pr "$pr_number" --arg head "$head" --arg headRepo "$headRepo" \
    '.[$pr] = {head: $head, headRepo: $headRepo}' "$PR_CACHE_FILE" > "${PR_CACHE_FILE}.tmp" && mv "${PR_CACHE_FILE}.tmp" "$PR_CACHE_FILE"
  echo "$out"
}

# --- Resolve target branch ref ---
resolve_target() {
  local arg="${1:-}"
  local slug
  slug=$(get_repo_slug)

  if [[ -z "$arg" ]]; then
    TARGET_REF="upstream/main"
    git fetch upstream --no-tags
    return
  fi

  if [[ "$arg" =~ ^[0-9]+$ ]]; then
    if [[ -z "$slug" ]]; then
      echo "sync: need 'gh' and repo (or origin/upstream URL) to resolve PR #${arg}." >&2
      exit 1
    fi
    if ! command -v jq &>/dev/null; then
      echo "sync: 'jq' is required for PR cache. Install jq or use branch name." >&2
      exit 1
    fi
    local pr_info
    pr_info=$(get_pr_branch_info "$arg" "$slug")
    local head_ref head_repo
    head_ref=$(echo "$pr_info" | jq -r '.head')
    head_repo=$(echo "$pr_info" | jq -r '.headRepo')
    if git show-ref --quiet -- "refs/heads/${head_ref}"; then
      TARGET_REF="$head_ref"
      return
    fi
    local fetch_remote="pr-$arg"
    if ! git remote get-url "$fetch_remote" &>/dev/null; then
      git remote add "$fetch_remote" "https://${GH_HOST}/${head_repo}.git" 2>/dev/null || true
    fi
    git fetch "$fetch_remote" "$head_ref" --no-tags 2>/dev/null || true
    TARGET_REF="${fetch_remote}/${head_ref}"
    return
  fi

  if git show-ref --quiet -- "refs/heads/${arg}"; then
    TARGET_REF="$arg"
    # Local branch: still fetch upstream/origin so base is fresh if we rebase onto remote later
    git fetch upstream --no-tags 2>/dev/null || true
    git fetch origin --no-tags 2>/dev/null || true
    return
  fi
  if git show-ref --quiet -- "refs/remotes/upstream/${arg}"; then
    git fetch upstream --no-tags
    TARGET_REF="upstream/${arg}"
    return
  fi
  if git show-ref --quiet -- "refs/remotes/origin/${arg}"; then
    git fetch origin --no-tags
    TARGET_REF="origin/${arg}"
    return
  fi
  git fetch upstream --no-tags
  if git show-ref --quiet -- "refs/remotes/upstream/${arg}"; then
    TARGET_REF="upstream/${arg}"
    return
  fi
  git fetch origin --no-tags
  if git show-ref --quiet -- "refs/remotes/origin/${arg}"; then
    TARGET_REF="origin/${arg}"
    return
  fi
  echo "sync: branch or ref '${arg}' not found locally or on upstream/origin." >&2
  exit 1
}

main() {
  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    echo "sync: not inside a git repository." >&2
    exit 1
  fi

  local arg="${1:-}"
  resolve_target "$arg"

  BRANCH_NAME=$(git branch --show-current)
  if [[ -z "$BRANCH_NAME" ]]; then
    echo "sync: detached HEAD. Checkout a branch first." >&2
    exit 1
  fi

  echo "Rebasing HEAD onto ${TARGET_REF} (--onto ${TARGET_REF} HEAD~1 ${BRANCH_NAME})"
  if ! git rebase --onto "$TARGET_REF" HEAD~1 "$BRANCH_NAME"; then
    echo ""
    echo "sync: rebase had conflicts. Resolve conflicts, then run:"
    echo "  git add <resolved-files>"
    echo "  git rebase --continue"
    exit 1
  fi
  echo "sync: done."
}

main "$@"
